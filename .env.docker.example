# Copy to .env.docker for local Docker runs:
#   cp .env.docker.example .env.docker
# For CI/CD, map these to GitHub Actions secrets / repository variables.

# ── Paths (local full-stack compose) ──
FE_BUILD_CONTEXT=../internship_application_coordinator_fe

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=internship_coordinator
POSTGRES_USER=coordinator
POSTGRES_PASSWORD=change-me

# ── Spring ──
SPRING_PROFILES_ACTIVE=docker

# ── Vertex AI / Gemini ──
VERTEX_AI_ENABLED=true
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=europe-west1
GCP_GEMINI_MODEL=gemini-2.5-flash
# Local file path is set automatically by docker-entrypoint.sh from GCP_SERVICE_ACCOUNT_JSON
GCP_SERVICE_ACCOUNT_JSON=

# ── CORS (browser origin for the frontend container) ──
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── File uploads ──
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# ── Email intake (optional) ──
EMAIL_INTAKE_ENABLED=false
EMAIL_INTAKE_MODE=imap
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_USERNAME=
GMAIL_IMAP_PASSWORD=
GMAIL_IMAP_FOLDER=INBOX
EMAIL_INTAKE_POLL_INTERVAL_SECONDS=60

# ── Optional features ──
TEST_DATASET_ENABLED=false

# ── Published ports ──
API_PORT=8080
WEB_PORT=5173
