# PostgreSQL (used by docker-compose and Spring Boot local profile)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=internship_coordinator
POSTGRES_USER=coordinator
POSTGRES_PASSWORD=coordinator

# Vertex AI / Gemini (BE-07 — do not commit real credentials)
# Local dev: point to a service account JSON file on disk.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
# Docker / CI: pass the full JSON via GCP_SERVICE_ACCOUNT_JSON (see .env.docker.example).
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GCP_PROJECT_ID=intern_application_coordinator
GCP_REGION=europe-west1
GCP_GEMINI_MODEL=gemini-2.5-flash
VERTEX_AI_ENABLED=false

# File uploads (BE-06)
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# University rules (BE-10)
UNIVERSITY_RULES_CONFIG_PATH=classpath:university-rules.json

# CORS (BE-17)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Email intake (BE-16 — IMAP local dev; use Gmail App Password, not account password)
EMAIL_INTAKE_ENABLED=false
EMAIL_INTAKE_MODE=imap
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_USERNAME=your@gmail.com
GMAIL_IMAP_PASSWORD=your-app-password
GMAIL_IMAP_FOLDER=INBOX
GMAIL_IMAP_CONNECTION_TIMEOUT_MS=10000
GMAIL_IMAP_READ_TIMEOUT_MS=30000
EMAIL_INTAKE_MAX_UNREAD_PER_POLL=50
EMAIL_INTAKE_POLL_INTERVAL_SECONDS=60
# Optional Gmail-only filter (default: is:unread has:attachment filename:pdf)
# GMAIL_IMAP_RAW_SEARCH_QUERY=is:unread has:attachment filename:pdf newer_than:90d

# Test dataset seed (BE-18)
TEST_DATASET_ENABLED=false
